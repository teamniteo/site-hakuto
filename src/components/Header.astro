---
import HakutoLogo from "@/assets/hakuto-dark.svg";
import { ArrowRight, ExternalLink } from "lucide-react";

const nav = [
  { href: "/skills", label: "Skills" },
  { href: "/docs", label: "Docs" },
  { href: "/blog", label: "Blog" },
  { href: "https://github.com/teamniteo/hakuto/discussions", label: "Community", external: true },
];

const isHome = Astro.url.pathname === "/";
---

<header class="border-b border-border bg-card/80 backdrop-blur sticky top-0 z-40">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center text-heading" aria-label="Hakuto home">
      <HakutoLogo class="h-7 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm font-mono">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-muted-foreground hover:text-heading transition-colors inline-flex items-center gap-1"
          {...(item.external ? { target: "_blank", rel: "noreferrer" } : {})}
        >
          {item.label}
          {item.external && <ExternalLink className="h-3 w-3" />}
        </a>
      ))}
      <a
        id="nav-cta"
        href="/start/prep"
        class:list={[
          "inline-flex items-center gap-1.5 whitespace-nowrap rounded-md px-4 py-1.5 transition-colors",
          isHome
            ? "border border-input-border text-heading hover:bg-accent hover:text-accent-foreground"
            : "bg-primary text-primary-foreground hover:opacity-90",
        ]}
      >
        Start building
        <ArrowRight className="h-3.5 w-3.5" />
      </a>
    </nav>

    <button
      id="mobile-nav-toggle"
      class="md:hidden inline-flex items-center justify-center h-9 w-9 rounded-md border border-input-border text-heading"
      aria-label="Toggle navigation"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <div id="mobile-nav" class="hidden md:hidden border-t border-border bg-card">
    <nav class="max-w-[1200px] mx-auto px-4 sm:px-6 py-4 flex flex-col gap-3 font-mono text-sm">
      {nav.map((item) => (
        <a
          href={item.href}
          class="text-muted-foreground hover:text-heading transition-colors inline-flex items-center gap-1"
          {...(item.external ? { target: "_blank", rel: "noreferrer" } : {})}
        >
          {item.label}
          {item.external && <ExternalLink className="h-3 w-3" />}
        </a>
      ))}
      <a
        href="/start/prep"
        class="rounded-md bg-primary px-4 py-2 text-primary-foreground hover:opacity-90 transition-colors text-center"
      >
        Start building
        <ArrowRight className="h-3.5 w-3.5" />
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const menu = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });

  // On homepage: switch nav CTA to primary style once user scrolls past hero
  const cta = document.getElementById("nav-cta");
  if (cta && window.location.pathname === "/") {
    const hero = document.querySelector("section");
    if (hero) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            cta.classList.remove("bg-primary", "text-primary-foreground");
            cta.classList.add("border", "border-input-border", "text-heading", "hover:bg-accent", "hover:text-accent-foreground");
          } else {
            cta.classList.add("bg-primary", "text-primary-foreground");
            cta.classList.remove("border", "border-input-border", "text-heading", "hover:bg-accent", "hover:text-accent-foreground");
          }
        },
        { threshold: 0 }
      );
      observer.observe(hero);
    }
  }
</script>
