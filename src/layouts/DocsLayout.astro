---
import Layout from "./Layout.astro";
import DocsSidebar from "@/components/DocsSidebar.astro";
import { getCollection } from "astro:content";
import type { Thing, WithContext } from "schema-dts";

interface Props {
  title: string;
  description?: string;
  schema?: WithContext<Thing> | WithContext<Thing>[];
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, schema, headings } = Astro.props;

const allDocs = await getCollection("docs", ({ data }) => !data.draft);

// Filter headings to H2 and H3 for table of contents
const tocHeadings = headings?.filter((h) => h.depth === 2 || h.depth === 3) ?? [];
---

<Layout title={`Docs - ${title}`} description={description} schema={schema}>
  <div class="docs-wrapper">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-12">
      <div class="lg:flex lg:gap-10">
        <!-- Sidebar -->
        <DocsSidebar docs={allDocs} />

        <!-- Main content column -->
        <article class="docs-article flex-1 min-w-0 max-w-[680px]">
          <slot />
        </article>

          <!-- Table of contents (right side) -->
          {tocHeadings.length > 2 && (
            <nav class="docs-toc hidden xl:block w-[200px] shrink-0">
              <div class="sticky top-24">
                <p class="docs-toc-label">On this page</p>
                <ul class="docs-toc-list">
                  {tocHeadings.map((h) => (
                    <li>
                      <a
                        href={`#${h.slug}`}
                        class:list={["docs-toc-link", h.depth === 3 && "docs-toc-indent"]}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </nav>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // External links open in new tab
  document.querySelectorAll('.docs-article a[href^="http"]').forEach((link) => {
    link.setAttribute('target', '_blank');
    link.setAttribute('rel', 'noopener noreferrer');
  });

  // Copy button on code blocks
  document.querySelectorAll('.docs-article pre').forEach((pre) => {
    const wrapper = document.createElement('div');
    wrapper.className = 'docs-code-wrapper';
    pre.parentNode!.insertBefore(wrapper, pre);
    wrapper.appendChild(pre);

    const btn = document.createElement('button');
    btn.className = 'docs-copy-btn';
    btn.setAttribute('aria-label', 'Copy code');
    btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
    wrapper.appendChild(btn);

    btn.addEventListener('click', () => {
      const code = pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
      navigator.clipboard.writeText(code).then(() => {
        btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        setTimeout(() => {
          btn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
        }, 2000);
      });
    });
  });
</script>

<style is:global>
  /* ── Docs design system — uses site theme variables ── */
  .docs-wrapper {
    background: hsl(var(--background));
    min-height: calc(100vh - 4rem);
  }

  /* ── Article prose styling ── */
  .docs-article h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: hsl(var(--heading));
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .docs-article h2 {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.3;
    color: hsl(var(--heading));
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid hsl(var(--border));
  }

  .docs-article h3 {
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.4;
    color: hsl(var(--heading));
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .docs-article > p,
  .docs-article > ul,
  .docs-article > ol,
  .docs-article > blockquote {
    font-size: 1rem;
    line-height: 1.8;
    color: hsl(var(--foreground));
    margin-bottom: 1.25rem;
  }

  .docs-article a {
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .docs-article a:hover {
    text-decoration: underline;
  }

  .docs-article strong {
    color: hsl(var(--heading));
    font-weight: 600;
  }

  /* Lists */
  .docs-article ul,
  .docs-article ol {
    padding-left: 1.5rem;
  }

  .docs-article ul {
    list-style-type: disc;
  }

  .docs-article ol {
    list-style-type: decimal;
  }

  .docs-article li {
    margin-bottom: 0.4rem;
    line-height: 1.7;
    color: hsl(var(--foreground));
  }

  .docs-article li strong {
    color: hsl(var(--heading));
  }

  /* Inline code */
  .docs-article code:not(pre code) {
    font-size: 0.875rem;
    background: hsl(var(--secondary));
    border: 1px solid hsl(var(--border));
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    color: hsl(var(--accent-foreground));
  }

  /* Code blocks */
  .docs-code-wrapper {
    position: relative;
    margin-bottom: 1.25rem;
  }

  .docs-code-wrapper pre {
    margin-bottom: 0;
  }

  .docs-copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.35rem;
    border: 1px solid hsl(var(--border));
    border-radius: 4px;
    background: hsl(var(--secondary));
    color: hsl(var(--muted-foreground));
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    line-height: 0;
  }

  .docs-copy-btn:hover {
    color: hsl(var(--foreground));
    background: hsl(var(--background));
  }

  .docs-article pre {
    font-size: 0.875rem;
    line-height: 1.6;
    background: hsl(var(--secondary));
    border: 1px solid hsl(var(--border));
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
    color: hsl(var(--heading));
  }

  .docs-article pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
    color: inherit;
  }

  /* Tables */
  .docs-article table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .docs-article th {
    text-align: left;
    font-weight: 600;
    color: hsl(var(--heading));
    padding: 0.6rem 1rem;
    border-bottom: 2px solid hsl(var(--border));
  }

  .docs-article td {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid hsl(var(--border));
    color: hsl(var(--foreground));
  }

  .docs-article td code {
    font-size: 0.8rem;
  }

  /* Blockquotes (tips/notes) */
  .docs-article blockquote {
    border-left: 3px solid hsl(var(--primary) / 0.4);
    padding: 0.5rem 1rem;
    margin: 1.25rem 0;
    color: hsl(var(--muted-foreground));
  }

  .docs-article blockquote p {
    margin-bottom: 0;
  }

  .docs-article blockquote strong {
    color: hsl(var(--foreground));
  }

  /* Horizontal rules */
  .docs-article hr {
    border: none;
    border-top: 1px solid hsl(var(--border));
    margin: 2rem 0;
  }

  /* Table of contents */
  .docs-toc-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: hsl(var(--muted-foreground));
    margin-bottom: 0.75rem;
  }

  .docs-toc-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .docs-toc-link {
    display: block;
    font-size: 13px;
    line-height: 1.4;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.15s;
  }

  .docs-toc-link:hover {
    color: hsl(var(--foreground));
  }

  .docs-toc-indent {
    padding-left: 0.75rem;
  }
</style>
