---
import DocsLayout from "@/layouts/DocsLayout.astro";
import { getCollection } from "astro:content";

const allDocs = await getCollection("docs", ({ data }) => !data.draft);

const categoryOrder = ["setting-up", "tips", "customization"];
const categoryLabels: Record<string, string> = {
  "setting-up": "Setting Up",
  tips: "Tips",
  customization: "Customization",
};

const categories = categoryOrder
  .map((slug) => ({
    label: categoryLabels[slug] || slug,
    items: allDocs
      .filter((doc) => doc.data.category === slug)
      .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)),
  }))
  .filter((cat) => cat.items.length > 0);
---

<DocsLayout
  title="Home"
  description="Guides and references for building modern Astro websites with Hakuto and Claude Code. Covers setup, deployment, customization, and more."
>
  <h1>Welcome to Hakuto</h1>
  <p>
    Hakuto is a free, open-source framework for building fast, modern websites with <a href="https://astro.build">Astro</a> and <a href="https://claude.ai/code">Claude Code</a>. It gives AI the context it needs to produce production-quality pages — from design systems and SEO to forms, blogs, and analytics.
  </p>

  {categories.map((cat) => (
    <div>
      <h2>{cat.label}</h2>
      <div class="docs-card-grid">
        {cat.items.map((doc) => (
          <a href={`/docs/${doc.id}`} class="docs-card">
            <span class="docs-card-title">{doc.data.title}</span>
            <span class="docs-card-desc">{doc.data.description}</span>
          </a>
        ))}
      </div>
    </div>
  ))}

  <div class="docs-help-box">
    <p>
      <strong>Need help?</strong> Can't find what you're looking for? <a href="https://github.com/teamniteo/hakuto/discussions" target="_blank" rel="noreferrer">Start a discussion</a> on GitHub or <a href="https://github.com/teamniteo/hakuto/issues" target="_blank" rel="noreferrer">open an issue</a> to request a guide.
    </p>
  </div>
</DocsLayout>

<style is:global>
  .docs-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .docs-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.15rem;
    border: 1px solid hsl(var(--border));
    border-radius: 6px;
    background: hsl(var(--secondary));
    color: inherit !important;
    text-decoration: none !important;
    transition: border-color 0.15s;
  }

  .docs-card:hover {
    border-color: hsl(var(--muted-foreground) / 0.4);
  }

  .docs-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: hsl(var(--heading));
  }

  .docs-card-desc {
    font-size: 0.825rem;
    line-height: 1.5;
    color: hsl(var(--foreground));
  }

  .docs-help-box {
    border: 1px dashed hsl(var(--border));
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-top: 2rem;
  }

  .docs-help-box p {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    margin: 0;
    line-height: 1.7;
  }

  .docs-help-box strong {
    color: hsl(var(--foreground));
  }

  .docs-help-box a {
    color: hsl(var(--primary));
    text-decoration: none;
  }

  .docs-help-box a:hover {
    text-decoration: underline;
  }
</style>
