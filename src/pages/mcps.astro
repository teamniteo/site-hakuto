---
import Layout from "@/layouts/Layout.astro";
import { Copy, Gauge, TestTube2, LineChart } from "lucide-react";

const mcps = [
  {
    name: "Clone Site",
    Icon: Copy,
    body: "Point Hakuto at any URL and Claude will recreate the site structure and design as an Astro project in your repo. Useful for migrations or starting from a reference design.",
  },
  {
    name: "Browser Testing",
    Icon: TestTube2,
    body: "Automatically checks your site after every deploy: forms, buttons, navigation, mobile layout. Get alerted when something breaks before your visitors do.",
  },
  {
    name: "PageSpeed",
    Icon: Gauge,
    body: "Runs Google PageSpeed Insights on your site and gives Claude the results. Claude can then suggest and implement specific fixes, not just tell you what's wrong.",
  },
  {
    name: "Search Console",
    Icon: LineChart,
    body: "Connects Claude to your Google Search Console data. Ask things like 'which pages dropped in rankings this month' and get actionable answers tied directly to your codebase.",
  },
];
---

<Layout
  title="MCPs"
  description="MCPs extend what Claude can do by connecting it to external services. Browse the upcoming paid MCPs for Hakuto — site cloning, browser testing, and more."
>
  <!-- HERO -->
  <section class="border-b border-border relative overflow-hidden">
    <div
      aria-hidden="true"
      class="absolute top-0 right-0 w-[500px] h-[300px] bg-primary/10 blur-[100px] rounded-full pointer-events-none"
    ></div>
    <div class="relative max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-primary mb-3">
        // MCPs
      </p>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <h1 class="font-mono text-3xl sm:text-4xl lg:text-5xl font-bold text-heading leading-[1.1]">
          MCPs: <span class="text-primary">coming soon</span>
        </h1>
        <div class="inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.2em] text-primary border border-primary/30 bg-primary/5 rounded-full px-3 py-1.5 flex-shrink-0 self-start lg:self-auto">
          <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
          In progress
        </div>
      </div>
    </div>
  </section>

  <!-- MCPS GRID -->
  <section class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid gap-6 md:grid-cols-2">
      {mcps.map(({ name, Icon, body }) => (
        <article class="group relative border border-border rounded-lg p-8 bg-card overflow-hidden">
          <div
            aria-hidden="true"
            class="absolute -top-16 -right-16 w-40 h-40 bg-primary/5 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
          ></div>
          <div class="relative">
            <div class="flex items-center justify-between mb-6">
              <div class="h-11 w-11 rounded-md bg-primary/10 border border-primary/20 flex items-center justify-center">
                <Icon className="h-5 w-5 text-primary" />
              </div>
              <span class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.2em] text-muted-foreground border border-border rounded-full px-2.5 py-1">
                <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
                Coming soon
              </span>
            </div>
            <h2 class="font-mono text-2xl font-semibold text-heading mb-3">{name}</h2>
            <p class="text-foreground leading-relaxed">{body}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

</Layout>
