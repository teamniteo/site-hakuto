---
import Layout from "@/layouts/Layout.astro";
import { Github, Package, Search, ImageIcon, Accessibility, ArrowRight } from "lucide-react";

const skills = [
  {
    name: "Astro",
    slug: "astro",
    Icon: Package,
    body: "Guides Claude on how to build and maintain Astro sites correctly: project structure, components, content collections, routing, and Astro best practices. Claude won't reinvent the wheel or make opinionated choices you'll regret later.",
    example: '"Set up a content collection for blog posts"',
  },
  {
    name: "SEO",
    slug: "seo",
    Icon: Search,
    body: "Teaches Claude how to handle on-page SEO for every page: meta titles and descriptions, Open Graph tags, canonical URLs, structured data (schema.org), and XML sitemaps. Ask Claude to 'do an SEO review' and it knows what to check.",
    example: '"Do an SEO review of every page"',
  },
  {
    name: "Image Optimization",
    slug: "images",
    Icon: ImageIcon,
    body: "Guides Claude on using Astro's built-in image optimization correctly: responsive images, lazy loading, correct format selection, and alt text. Keeps your Lighthouse scores clean without you having to think about it.",
    example: '"Optimize every image on the homepage"',
  },
  {
    name: "Accessibility Check",
    slug: "a11y",
    Icon: Accessibility,
    body: "Teaches Claude how to audit pages for common accessibility issues: heading structure, ARIA labels, color contrast flags, keyboard navigation, and form labeling. Ask Claude to 'check accessibility on this page' and it'll walk through it.",
    example: '"Check accessibility on the contact page"',
  },
];
---

<Layout
  title="Skills"
  description="Skills are instructions that live in your project and teach Claude Code how to handle specific tasks. Hakuto ships with four Skills out of the box."
>
  <!-- HERO -->
  <section class="border-b border-border">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-primary mb-5">
        // /.claude/skills
      </p>
      <h1 class="font-mono text-4xl sm:text-5xl lg:text-6xl font-bold text-heading leading-[1.05] max-w-3xl">
        What Claude knows <br />
        <span class="text-primary">how to do.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg text-foreground leading-relaxed">
        Skills are instructions that live in your project and teach Claude Code
        how to handle specific tasks. Hakuto includes four Skills out of the box.
        They're open source.
      </p>
      <div class="mt-8">
        <a
          href="https://github.com/teamniteo/hakuto/tree/main/.claude/skills"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 font-mono text-sm text-primary hover:underline"
        >
          <Github className="h-4 w-4" />
          Browse them on GitHub
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- SKILLS GRID -->
  <section class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid gap-6 lg:grid-cols-2">
      {skills.map(({ name, slug, Icon, body, example }) => (
        <article class="group relative border border-border rounded-lg p-8 bg-card hover:border-primary/50 transition-colors flex flex-col">
          <div class="flex items-center justify-between mb-6">
            <div class="inline-flex items-center gap-3">
              <div class="h-10 w-10 rounded-md bg-primary/10 border border-primary/20 flex items-center justify-center">
                <Icon className="h-5 w-5 text-primary" />
              </div>
              <h2 class="font-mono text-2xl font-semibold text-heading">{name}</h2>
            </div>
            <code class="font-mono text-xs text-muted-foreground">/{slug}</code>
          </div>

          <p class="text-foreground leading-relaxed flex-1">{body}</p>

          <div class="mt-6 pt-6 border-t border-border">
            <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted-foreground mb-2">Try it</p>
            <p class="font-mono text-sm text-primary">{example}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="font-mono text-2xl font-semibold text-heading mb-2">
            More Skills, same philosophy.
          </h2>
          <p class="text-muted-foreground max-w-xl">
            We're adding more Skills as we find patterns worth teaching Claude.
            Want one? Open an issue or a PR.
          </p>
        </div>
        <a
          href="https://github.com/teamniteo/hakuto/issues"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-input-border px-5 py-3 font-mono text-sm text-heading hover:bg-accent hover:text-accent-foreground transition-colors whitespace-nowrap"
        >
          <Github className="h-4 w-4" />
          Request a Skill
        </a>
      </div>
    </div>
  </section>
</Layout>
