---
import Layout from "@/layouts/Layout.astro";
import { Github, Paintbrush, PenTool, Globe, FileText, BookOpen, FormInput, SearchCheck, ClipboardCheck, Rocket, Hammer, ArrowRight } from "lucide-react";

const skills = [
  {
    name: "Website Builder",
    slug: "website-builder",
    Icon: Hammer,
    body: "The orchestrator. Generates production-ready websites from a conversation. Picks a site type, applies a design language, coordinates copywriting and branding skills, and tracks every decision in a living spec file so pages stay consistent as your site evolves.",
    example: '"Build me a SaaS landing page"',
  },
  {
    name: "Brand Designer",
    slug: "brand-designer",
    Icon: Paintbrush,
    body: "Generates color palettes using real color theory: complementary, triadic, or analogous schemes based on your design language. Give it a hex code, a color name, or a logo to extract from, and it produces a full palette with proper contrast ratios.",
    example: '"Use my brand color #3B82F6"',
  },
  {
    name: "Professional Copywriter",
    slug: "professional-copywriter",
    Icon: PenTool,
    body: "Writes conversion-optimized website copy: benefit-driven headlines, scannable structure, clear CTAs. Knows what to generate when content is missing, what to expand from bullet points, and what to leave untouched when you've written it yourself.",
    example: '"Write copy for the pricing page"',
  },
  {
    name: "Browser Agent",
    slug: "agent-browser",
    Icon: Globe,
    body: "A full browser automation toolkit. Navigate pages, fill forms, take screenshots, record videos, intercept network requests, and extract data directly from the command line. Useful for testing your site, scraping reference content, or automating repetitive web tasks.",
    example: '"Take a screenshot of the homepage"',
  },
  {
    name: "Blog Section",
    slug: "section-blog",
    Icon: FileText,
    body: "Adds a complete blog system with listing pages, dynamic post routes, and two layout options: standard single-column for articles and flexible full-width for visual content. Uses Astro content collections with proper frontmatter schemas and category/author archives.",
    example: '"Add a blog to the site"',
  },
  {
    name: "Docs Section",
    slug: "section-docs",
    Icon: BookOpen,
    body: "Adds a technical documentation section with sidebar navigation, search via Pagefind, and auto-generated table of contents. Uses its own minimal design system (monochrome plus blue links) so docs stay readable regardless of your main site's aesthetic.",
    example: '"Add documentation pages"',
  },
  {
    name: "Form Section",
    slug: "section-form",
    Icon: FormInput,
    body: "Builds accessible, validated forms using React islands with Zod schemas. Contact forms, newsletter signups, and waitlists with field-level validation on blur, proper ARIA attributes, and submission to a Cloudflare Worker endpoint.",
    example: '"Add a contact form"',
  },
  {
    name: "Code Review",
    slug: "code-review",
    Icon: ClipboardCheck,
    body: "A report-only source audit that complements SEO Audit. Checks src/ against the rules in CLAUDE.md: Tailwind v4 import order, className vs class on shadcn, Picture for local images, Fonts API usage, Cloudflare adapter options, anchor-link targets, and template placeholder cleanup. Cites file:line plus the rule it violates.",
    example: '"Run a code review"',
  },
  {
    name: "SEO Audit",
    slug: "seo-audit",
    Icon: SearchCheck,
    body: "Builds the site, then audits every page for SEO issues: missing meta tags, broken heading hierarchy, invalid JSON-LD, duplicate titles, orphaned pages, and missing sitemaps. Reports findings with severity levels so you decide what to fix.",
    example: '"Run an SEO test on all pages"',
  },
  {
    name: "Plausible Analytics",
    slug: "plausible-analytics",
    Icon: Globe,
    body: "Adds privacy-friendly Plausible Analytics with a Cloudflare Workers proxy that bypasses ad blockers. Strips cookies, serves the tracking script from your own domain, and caches at the edge without leaking visitor data to third parties.",
    example: '"Add analytics tracking"',
  },
  {
    name: "Prelaunch Checklist",
    slug: "prelaunch-checklist",
    Icon: Rocket,
    body: "Walks the repo before you go live and reports what's ready and what's not: scaffold defaults still in Layout.astro, placeholder copy in source, forms wired to real endpoints, wrangler config customized, legal pages linked from the footer. Confirms you've run the SEO and code-review skills, then lists the manual Cloudflare dashboard steps it can't automate.",
    example: '"Run prelaunch checklist"',
  },
];
---

<Layout
  title="Skills"
  description="Skills are instructions that live in your project and teach Claude Code how to handle specific tasks. Hakuto ships with eleven Skills out of the box."
>
  <!-- HERO -->
  <section class="border-b border-border">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-primary mb-3">
        // /skills
      </p>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4">
        <h1 class="font-mono text-3xl sm:text-4xl lg:text-5xl font-bold text-heading leading-[1.1]">
          Hakuto Skills for <span class="text-primary">Claude Code</span>
        </h1>
        <a
          href="https://github.com/teamniteo/hakuto/tree/main/skills"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 font-mono text-sm text-primary hover:underline flex-shrink-0"
        >
          <Github className="h-4 w-4" />
          Browse on GitHub
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- SKILLS GRID -->
  <section class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid gap-6 lg:grid-cols-2">
      {skills.map(({ name, slug, Icon, body, example }) => (
        <a
          href={`https://github.com/teamniteo/hakuto/tree/main/skills/${slug}`}
          target="_blank"
          rel="noreferrer"
          class="group relative border border-border rounded-lg p-8 bg-card hover:border-primary/50 transition-colors flex flex-col"
        >
          <div class="flex items-center justify-between mb-6">
            <div class="inline-flex items-center gap-3">
              <div class="h-10 w-10 rounded-md bg-primary/10 border border-primary/20 flex items-center justify-center">
                <Icon className="h-5 w-5 text-primary" />
              </div>
              <h2 class="font-mono text-2xl font-semibold text-heading">{name}</h2>
            </div>
            <code class="font-mono text-xs text-muted-foreground inline-flex items-center gap-1.5">
              /{slug}
              <Github className="h-3.5 w-3.5 opacity-60 group-hover:opacity-100 transition-opacity" />
            </code>
          </div>

          <p class="text-foreground leading-relaxed flex-1">{body}</p>

          <div class="mt-6 pt-6 border-t border-border">
            <p class="font-mono text-xs uppercase tracking-[0.15em] text-muted-foreground mb-2">Try it</p>
            <p class="font-mono text-sm text-primary">{example}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <h2 class="font-mono text-2xl font-semibold text-heading mb-2">
            More Skills, same philosophy.
          </h2>
          <p class="text-foreground max-w-xl">
            We're adding more Skills as we find patterns worth teaching Claude.
            Want one? Open an issue or a PR.
          </p>
        </div>
        <a
          href="https://github.com/teamniteo/hakuto/issues"
          target="_blank"
          rel="noreferrer"
          class="inline-flex items-center gap-2 rounded-md border border-input-border px-5 py-3 font-mono text-sm text-heading hover:bg-accent hover:text-accent-foreground transition-colors whitespace-nowrap"
        >
          <Github className="h-4 w-4" />
          Request a Skill
        </a>
      </div>
    </div>
  </section>
</Layout>
