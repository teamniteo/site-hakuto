---
import Layout from "@/layouts/Layout.astro";
import {
  Terminal,
  GitBranch,
  Cloud,
  Code,
  GitPullRequest,
  CheckCircle2,
  Check,
  Copy,
  ArrowRight,
  ArrowLeft,
  ListChecks,
  Package,
} from "lucide-react";

type Step = {
  key: string;
  label: string;
  Icon: typeof GitBranch;
  title: string;
  intro?: string;
  code?: string;
  checklist?: string[];
  outro?: string;
};

const steps: Step[] = [
  {
    key: "prep",
    label: "Prep",
    Icon: ListChecks,
    title: "Before you start",
    intro:
      "A few free accounts and tools you'll need. Grab anything you're missing and come back. The rest takes about 5 minutes.",
    checklist: [
      `A <a href="https://claude.ai/code" target="_blank" rel="noreferrer" class="text-primary hover:underline">Claude Code</a> account, the AI coding agent that builds your site.`,
      `A <a href="https://github.com/signup" target="_blank" rel="noreferrer" class="text-primary hover:underline">GitHub account</a> (free) to host your site's code.`,
      `A <a href="https://dash.cloudflare.com/sign-up" target="_blank" rel="noreferrer" class="text-primary hover:underline">Cloudflare account</a> (free) to deploy and host your site.`,
      `<a href="https://bun.sh" target="_blank" rel="noreferrer" class="text-primary hover:underline">Bun</a> installed locally (Hakuto uses Bun, not npm).`,
    ],
    outro: "Got everything? Let's install Hakuto.",
  },
  {
    key: "install",
    label: "Install",
    Icon: Package,
    title: "Install the plugin and scaffold a site",
    // Custom-rendered below — see step.key === "install" branch.
  },
  {
    key: "build",
    label: "Build",
    Icon: Code,
    title: "Tell Claude what to build",
    intro:
      "Claude is already in your new project — you opened it for /hakuto:init. Describe the site you want. Here's an example prompt:",
    code: `Build a website for an analytics SaaS.
Use a modern, bold style with sharp typography and vibrant accents.
Write convincing, benefit-driven copy that speaks to data teams.
Include a hero section, feature grid, pricing table, and a call-to-action.`,
    outro:
      "The website-builder skill auto-activates and drives the workflow: site type, design language, copy, brand colors, components. Watch it happen in the preview at localhost:4321.",
  },
  {
    key: "push",
    label: "Push",
    Icon: GitPullRequest,
    title: "Push to GitHub",
    intro:
      "Make sure you have the GitHub MCP server or GitHub CLI installed in Claude Code. If you're not sure, ask Claude to help you set it up. Then give it this prompt:",
    code: `Create new repository 'my-website' and push.`,
    outro: "Your code now lives on GitHub and is ready to deploy.",
  },
  {
    key: "cloudflare",
    label: "Deploy",
    Icon: Cloud,
    title: "Deploy to Cloudflare",
    intro: "Cloudflare gives you a free, globally distributed host with PR previews baked in.",
    checklist: [
      `Go to <a href="https://dash.cloudflare.com" target="_blank" rel="noreferrer" class="text-primary hover:underline">Cloudflare</a>, open <strong class="text-heading">Compute → Workers & Pages</strong> and click the <strong class="text-heading">Create Application</strong> button in the top right.`,
      `Select <strong class="text-heading">Continue with GitHub</strong>, then pick your organization and repository.`,
      `It will figure out the build and deploy commands on its own. Click <strong class="text-heading">Deploy</strong> without changing anything.`,
      `Wait for the site to be deployed. Once it's done, you'll get redirected to the Worker page. Click <strong class="text-heading">Visit</strong> to see your live site on a Cloudflare subdomain.`,
      `You can set up a custom domain under Settings. More on that in our <a href="/docs/setting-up/custom-domain" class="text-primary hover:underline">custom domain guide</a>, but you can skip it for now.`,
    ],
    outro: "Your site is live. Time to iterate.",
  },
  {
    key: "ship",
    label: "Ship",
    Icon: Terminal,
    title: "Preview and ship",
    // Custom-rendered below — see step.key === "ship" branch.
  },
];

export async function getStaticPaths() {
  const stepKeys = [
    "prep",
    "install",
    "build",
    "push",
    "cloudflare",
    "ship",
  ];
  return stepKeys.map((key) => ({ params: { step: key } }));
}

const { step: stepParam } = Astro.params;
const currentIndex = steps.findIndex((s) => s.key === stepParam);
const step = steps[currentIndex];
const Icon = step.Icon;
const total = steps.length;
const pad = (n: number) => String(n).padStart(2, "0");
const prev = currentIndex > 0 ? steps[currentIndex - 1] : null;
const next = currentIndex < total - 1 ? steps[currentIndex + 1] : null;
const isLast = currentIndex === total - 1;
---

<Layout
  title={`Start - ${step.label}`}
  description="Get your Hakuto site running in 5 minutes with a step-by-step walkthrough."
>
  <!-- HERO -->
  <section class="border-b border-border">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12">
      <p class="font-mono text-[11px] uppercase tracking-[0.25em] text-primary mb-3">
        // Onboarding
      </p>
      <h1 class="font-mono text-3xl sm:text-4xl lg:text-5xl font-bold text-heading leading-[1.1]">
        Get your site running <span class="text-primary">in 5 minutes</span>
      </h1>
    </div>
  </section>

  <!-- WIZARD -->
  <section class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div>
      <!-- STEPPER -->
      <nav class="flex items-start w-full mb-10" aria-label="Onboarding progress">
        {
          steps.map((s, i) => {
            const isCurrent = i === currentIndex;
            const isDone = i < currentIndex;
            const circleClasses = [
              "flex items-center justify-center w-8 h-8 rounded-full text-xs font-mono font-semibold flex-shrink-0 transition-all duration-300 border",
              isDone
                ? "bg-primary text-primary-foreground border-primary"
                : isCurrent
                  ? "bg-card text-primary border-primary scale-110"
                  : "bg-card text-muted-foreground border-border",
            ].join(" ");
            const labelClasses = [
              "mt-1.5 text-[10px] font-mono uppercase tracking-[0.15em] transition-colors duration-300",
              i <= currentIndex ? "text-primary" : "text-muted-foreground",
            ].join(" ");
            const lineClasses = [
              "flex-1 mt-4 h-[2px] transition-colors duration-300",
              i <= currentIndex ? "bg-primary" : "bg-border",
            ].join(" ");
            return (
              <>
                {i > 0 && <div class={lineClasses} />}
                <a
                  href={`/start/${s.key}`}
                  class="group flex flex-col items-center flex-shrink-0 focus:outline-none"
                  aria-label={`Go to step ${i + 1}: ${s.label}`}
                  aria-current={isCurrent ? "step" : undefined}
                >
                  <span class={circleClasses}>
                    {isDone ? (
                      <Check className="h-3.5 w-3.5" strokeWidth={3} />
                    ) : (
                      pad(i + 1)
                    )}
                  </span>
                  <span class={labelClasses}>{s.label}</span>
                </a>
              </>
            );
          })
        }
      </nav>

      <!-- STEP PANEL -->
      <article class="animate-step-in">
        <div class="rounded-lg border border-border bg-card p-7 sm:p-10">
          <div class="flex items-center gap-3 mb-6">
            <span class="flex items-center justify-center h-10 w-10 rounded-md bg-primary/10 border border-primary/30">
              <Icon className="h-5 w-5 text-primary" />
            </span>
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-primary">
                Step {pad(currentIndex + 1)} / {pad(total)}
              </p>
              <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-heading leading-tight">
                {step.title}
              </h2>
            </div>
          </div>

          {
            step.key === "install" && (
              <div class="space-y-6">
                <p class="text-foreground leading-relaxed">
                  Hakuto is a Claude Code plugin. You install it once, globally, and can scaffold
                  new sites in any empty directory thereafter.
                </p>

                <div>
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-primary mb-3">
                    // Step 1 · Install the plugin (one-time)
                  </p>
                  <p class="text-foreground leading-relaxed mb-3">
                    Open Claude Code and run these two slash commands:
                  </p>
                  <div class="relative group">
                    <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>/plugin marketplace add teamniteo/hakuto
/plugin install hakuto@hakuto</code></pre>
                    <button
                      type="button"
                      class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                      data-copy-btn
                      aria-label="Copy commands to clipboard"
                    >
                      <span data-copy-icon><Copy className="h-4 w-4" /></span>
                      <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                    </button>
                  </div>
                </div>

                <div>
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-primary mb-3">
                    // Step 2 · Scaffold a new site
                  </p>
                  <p class="text-foreground leading-relaxed mb-3">
                    In your terminal, create an empty directory and launch Claude Code inside it:
                  </p>
                  <div class="relative group">
                    <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>mkdir my-site && cd my-site
claude</code></pre>
                    <button
                      type="button"
                      class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                      data-copy-btn
                      aria-label="Copy commands to clipboard"
                    >
                      <span data-copy-icon><Copy className="h-4 w-4" /></span>
                      <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                    </button>
                  </div>
                  <p class="text-foreground leading-relaxed mt-4 mb-3">
                    Then, inside Claude, run:
                  </p>
                  <div class="relative group">
                    <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>/hakuto:init</code></pre>
                    <button
                      type="button"
                      class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                      data-copy-btn
                      aria-label="Copy command to clipboard"
                    >
                      <span data-copy-icon><Copy className="h-4 w-4" /></span>
                      <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                    </button>
                  </div>
                  <p class="text-foreground leading-relaxed mt-4">
                    The scaffold drops a ready-to-go Astro project in your directory and initializes a git repo.
                  </p>
                </div>

                <div>
                  <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-primary mb-3">
                    // Step 3 · Start the dev server
                  </p>
                  <p class="text-foreground leading-relaxed mb-3">
                    In a separate terminal (so Claude keeps running):
                  </p>
                  <div class="relative group">
                    <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>bun install
bun run dev</code></pre>
                    <button
                      type="button"
                      class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                      data-copy-btn
                      aria-label="Copy commands to clipboard"
                    >
                      <span data-copy-icon><Copy className="h-4 w-4" /></span>
                      <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                    </button>
                  </div>
                  <p class="text-foreground leading-relaxed mt-4">
                    Open <a href="http://localhost:4321" target="_blank" rel="noreferrer" class="text-primary hover:underline">localhost:4321</a> to see the fresh scaffold. It's intentionally blank — next step, you tell Claude what to build into it.
                  </p>
                </div>
              </div>
            )
          }

          {
            step.key === "ship" && (
              <div class="space-y-5">
                <p class="text-foreground leading-relaxed">
                  You don't need to go live immediately to see changes online. Cloudflare creates a preview URL for every Pull Request. Tell Claude:
                </p>
                <div class="relative group">
                  <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>Open PR for these changes.</code></pre>
                  <button
                    type="button"
                    class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                    data-copy-btn
                    aria-label="Copy command to clipboard"
                  >
                    <span data-copy-icon><Copy className="h-4 w-4" /></span>
                    <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                  </button>
                </div>
                <p class="text-foreground leading-relaxed">
                  Go to the PR on GitHub and wait a few seconds for the Cloudflare comment to appear with the branch preview URL.
                </p>
                <p class="text-foreground leading-relaxed">
                  If you're happy with the changes, merge the PR. If not, keep working with Claude and then tell it to:
                </p>
                <div class="relative group">
                  <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>Commit changes.</code></pre>
                  <button
                    type="button"
                    class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                    data-copy-btn
                    aria-label="Copy command to clipboard"
                  >
                    <span data-copy-icon><Copy className="h-4 w-4" /></span>
                    <span class="hidden text-emerald-500" data-check-icon><Check className="h-4 w-4" /></span>
                  </button>
                </div>
                <p class="text-foreground leading-relaxed">
                  That pushes the new commit and relaunches the preview URL with your latest changes.
                </p>
                <p class="text-foreground leading-relaxed">
                  To pick up newer plugin versions later, run <code class="font-mono text-primary">/plugin update hakuto</code> inside Claude Code — skills and commands update in place without a re-scaffold.
                </p>
              </div>
            )
          }

          {
            step.key !== "install" && step.key !== "ship" && step.intro && (
              <p class="text-foreground leading-relaxed mb-5">{step.intro}</p>
            )
          }

          {
            step.code && (
              <div class="relative group">
                <pre class="font-mono text-sm bg-background border border-border rounded-md p-5 pr-14 overflow-x-auto text-heading"><code data-code>{step.code}</code></pre>
                <button
                  type="button"
                  class="absolute top-3 right-3 p-2 rounded-md text-muted-foreground hover:text-heading hover:bg-accent transition-colors"
                  data-copy-btn
                  aria-label="Copy command to clipboard"
                >
                  <span data-copy-icon>
                    <Copy className="h-4 w-4" />
                  </span>
                  <span class="hidden text-emerald-500" data-check-icon>
                    <Check className="h-4 w-4" />
                  </span>
                </button>
              </div>
            )
          }

          {
            step.checklist && (
              <ol class="space-y-3 text-foreground mb-2">
                {step.checklist.map((item, j) => (
                  <li class="flex items-start gap-3">
                    <span class="flex-shrink-0 mt-0.5 flex items-center justify-center h-6 w-6 rounded-md border border-border bg-background font-mono text-[11px] text-primary">
                      {j + 1}
                    </span>
                    <span set:html={item} />
                  </li>
                ))}
              </ol>
            )
          }

          {
            step.outro && (
              <p class="mt-5 text-foreground leading-relaxed">
                {step.outro}
              </p>
            )
          }
        </div>
      </article>

      <!-- NAVIGATION -->
      <div class="flex items-center justify-between mt-8 gap-4">
        {
          prev ? (
            <a
              href={`/start/${prev.key}`}
              class="inline-flex items-center gap-2 rounded-md border border-border bg-card px-4 py-2.5 text-sm font-medium text-muted-foreground hover:text-heading hover:border-primary/50 transition-colors"
              rel="prev"
            >
              <ArrowLeft className="h-4 w-4" />
              Back
            </a>
          ) : (
            <span
              class="inline-flex items-center gap-2 rounded-md border border-border bg-card px-4 py-2.5 text-sm font-medium text-muted-foreground opacity-40 cursor-not-allowed"
              aria-disabled="true"
            >
              <ArrowLeft className="h-4 w-4" />
              Back
            </span>
          )
        }
        <p class="font-mono text-xs text-muted-foreground tabular-nums">
          {pad(currentIndex + 1)} / {pad(total)}
        </p>
        {
          next ? (
            <a
              href={`/start/${next.key}`}
              class="inline-flex items-center gap-2 rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
              rel="next"
            >
              Next
              <ArrowRight className="h-4 w-4" />
            </a>
          ) : (
            <a
              href="/docs"
              class="inline-flex items-center gap-2 rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:opacity-90 transition-opacity"
            >
              Read our docs
              <ArrowRight className="h-4 w-4" />
            </a>
          )
        }
      </div>
    </div>
  </section>

  {
    isLast && (
      <section class="border-t border-border">
        <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 py-20">
          <div class="relative overflow-hidden rounded-lg border border-border bg-card p-10 sm:p-14">
            <div
              aria-hidden="true"
              class="absolute -top-24 -right-24 w-[380px] h-[380px] bg-primary/15 blur-[100px] rounded-full pointer-events-none"
            />
            <div class="relative max-w-2xl">
              <CheckCircle2 className="h-8 w-8 text-primary mb-5" />
              <h2 class="font-mono text-3xl sm:text-4xl font-bold text-heading leading-tight">
                You're set.
              </h2>
              <p class="mt-5 text-lg text-foreground leading-relaxed">
                From here, just describe what you want to Claude and it'll handle the
                rest. If you get stuck, check the{" "}
                <a href="/docs" class="text-primary hover:underline">Docs</a> or browse the{" "}
                <a href="/skills" class="text-primary hover:underline">Skills</a> to see what
                Claude knows how to do.
              </p>
            </div>
          </div>
        </div>
      </section>
    )
  }
</Layout>

<script>
  // Copy-to-clipboard handlers for any [data-copy-btn] on the page.
  document.querySelectorAll<HTMLButtonElement>("[data-copy-btn]").forEach((btn) => {
    const wrapper = btn.parentElement;
    const codeEl = wrapper?.querySelector<HTMLElement>("[data-code]");
    const copyIcon = btn.querySelector<HTMLElement>("[data-copy-icon]");
    const checkIcon = btn.querySelector<HTMLElement>("[data-check-icon]");
    if (!codeEl || !copyIcon || !checkIcon) return;

    let timer: number | undefined;
    btn.addEventListener("click", async () => {
      const text = codeEl.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
      }
      copyIcon.classList.add("hidden");
      checkIcon.classList.remove("hidden");
      if (timer) window.clearTimeout(timer);
      timer = window.setTimeout(() => {
        copyIcon.classList.remove("hidden");
        checkIcon.classList.add("hidden");
      }, 2000);
    });
  });

  // Left/right arrow keys navigate between step pages.
  document.addEventListener("keydown", (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    const prevLink = document.querySelector<HTMLAnchorElement>('a[rel="prev"]');
    const nextLink = document.querySelector<HTMLAnchorElement>('a[rel="next"]');
    if (e.key === "ArrowRight" && nextLink) {
      window.location.href = nextLink.href;
    } else if (e.key === "ArrowLeft" && prevLink) {
      window.location.href = prevLink.href;
    }
  });
</script>
